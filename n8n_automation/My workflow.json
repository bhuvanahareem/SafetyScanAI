                "sendTo": "={{ $json.supervisor_email }}",
                "subject": "=SAFETY NOTICE: PPE Compliance Violation [{{ $json.sector_name }}] – {{ $json.timestamp.substring(0, 10) }}",
                "message": "=<div style=\"font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.6; color: #1a1a1a; max-width: 600px; border: 1px solid #eee; padding: 20px; border-radius: 8px;\">\n  \n  <div style=\"border-bottom: 2px solid #B53325; padding-bottom: 10px; margin-bottom: 20px;\">\n    <h2 style=\"color: #B53325; margin: 0; font-size: 18px;\">Security Intelligence Alert</h2>\n    <p style=\"margin: 0; font-size: 12px; color: #666;\">Sector Node: {{ $json.sector_name }} (ID: {{ $json.sector_id }})</p>\n  </div>\n\n  <!-- The AI generated formal report (already includes Greeting and Admin Signature) -->\n  <div style=\"white-space: pre-wrap; background: #ffffff; padding: 10px 0; font-size: 15px;\">\n{{ $json.agent_report }}\n  </div>\n\n  <!-- Legal Reference Section -->\n  <hr style=\"border: 0; border-top: 1px dashed #ccc; margin: 30px 0 15px 0;\">\n  <p style=\"font-size: 0.85rem; color: #666; font-style: italic; background: #fdf6f5; padding: 10px; border-radius: 4px;\">\n    <strong>Legal Reference (OSHA):</strong><br>\n    {{ $json.rag_snippet }}\n  </p>\n  \n  <p style=\"font-size: 0.7rem; color: #999; margin-top: 20px; text-align: center; border-top: 1px solid #eee; pt: 10px;\">\n    Report ID: {{ $json.violation_class }}-{{ $json.timestamp }}<br>\n    <strong>SafetyScanAI Command Center</strong> • 4K Surveillance Integration\n  </p>\n</div>\n",

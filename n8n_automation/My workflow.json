        {
            "parameters": {
                "jsCode": "// 1. Get the JSON data from the Webhook\nconst input = $input.first().json;\n\n// 2. Identify the data source\n// In n8n, the data might be at the top level OR inside a 'body' property.\n// This line handles both cases automatically.\nconst data = input.body ? input.body : input;\n\n// 3. Extract key fields for logic\nconst imageBase64 = data.image_base64;\nconst filename = data.image_filename || 'violation.jpg';\n\n// 4. STOP logic: Ensure we have an agent report and it's not a 'safe' detection\nif (!data.agent_report || data.violation_class === 'safe') {\n  return []; \n}\n\nif (!imageBase64) {\n  throw new Error(\"Could not find image_base64 inside the webhook body!\");\n}\n\n// 5. Return to n8n with binary and JSON merged\n// Merging 'data' here ensures {{ $json.user_email }} and {{ $json.agent_report }} \n// are available to subsequent nodes (like Gmail).\nreturn [\n  {\n    json: {\n      ...data  // This \"flattens\" everything into the $json object\n    },\n    binary: {\n      attachment: {\n        data: imageBase64,\n        mimeType: 'image/jpeg',\n        fileName: filename,\n        base64: true\n      }\n    }\n  }\n];\n"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
